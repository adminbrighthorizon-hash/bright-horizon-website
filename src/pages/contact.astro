---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>

<h1 class="text-5xl font-bold mb-4 text-gray-900">Get In Touch</h1>
<p class="text-xl text-gray-600 mb-12 max-w-2xl">Have a project in mind? We'd love to hear from you. Let's discuss how we can help your business grow.</p>

<div class="grid md:grid-cols-2 gap-12">
  <div>
    <h2 class="text-2xl font-bold mb-8 text-gray-900">Contact Information</h2>
    
    <div class="space-y-8">
      <div>
        <h3 class="font-semibold text-lg text-gray-900 mb-2">Email</h3>
        <a href="mailto:admin@brighthorizon.co.za" class="text-blue-600 hover:text-blue-700 font-medium">
          admin@brighthorizon.co.za
        </a>
      </div>
      
      <div>
        <h3 class="font-semibold text-lg text-gray-900 mb-2">Phone</h3>
        <a href="tel:+15551234567" class="text-blue-600 hover:text-blue-700 font-medium">
          (555) 123-4567
        </a>
      </div>
      
      <div>
        <h3 class="font-semibold text-lg text-gray-900 mb-2">Hours</h3>
        <p class="text-gray-700">Monday - Friday: 9:00 AM - 6:00 PM EST</p>
        <p class="text-gray-700">Weekend: Available by appointment</p>
      </div>
      
      <div class="bg-blue-50 p-6 rounded-lg border border-blue-100">
        <h3 class="font-semibold text-lg text-gray-900 mb-2">Quick Response</h3>
        <p class="text-gray-700">We typically respond to inquiries within 24 hours.</p>
      </div>
    </div>
  </div>
  
  <div>
    <form class="space-y-6 bg-gray-50 p-8 rounded-lg border border-gray-200">
      <div>
        <label for="name" class="block text-sm font-semibold text-gray-900 mb-2">Full Name *</label>
        <input
          id="name"
          type="text"
          placeholder="Your name"
          required
          class="w-full border border-gray-300 p-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-semibold text-gray-900 mb-2">Email Address *</label>
        <input
          id="email"
          type="email"
          placeholder="you@company.com"
          required
          class="w-full border border-gray-300 p-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent"
        />
      </div>

      <div>
        <label for="subject" class="block text-sm font-semibold text-gray-900 mb-2">Subject</label>
        <input
          id="subject"
          type="text"
          placeholder="What is this about?"
          class="w-full border border-gray-300 p-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-semibold text-gray-900 mb-2">Message *</label>
        <textarea
          id="message"
          placeholder="Tell us about your project..."
          required
          rows="6"
          class="w-full border border-gray-300 p-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 font-semibold transition-colors"
      >
        Send Message
      </button>
      
      <p class="text-xs text-gray-600 text-center">
        We respect your privacy. Your information will only be used to respond to your inquiry.
      </p>
    </form>
  </div>
</div>

</MainLayout>