---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>

<h1 class="text-5xl font-bold mb-4 text-gray-900">Our Services</h1>
<p class="text-xl text-gray-600 mb-12 max-w-2xl">Comprehensive digital solutions tailored to your business needs.</p>

<div class="grid md:grid-cols-3 gap-8 mb-12">
  <div class="border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow">
    <h2 class="text-2xl font-bold mb-4 text-gray-900">Website Development</h2>
    <p class="text-gray-700 mb-4 leading-relaxed">
      Fast, responsive, SEO-optimized websites built with modern frameworks. We create digital experiences that convert visitors into customers.
    </p>
    <ul class="text-gray-600 space-y-2 text-sm">
      <li>✓ Responsive Design</li>
      <li>✓ SEO Optimization</li>
      <li>✓ Performance Optimization</li>
      <li>✓ Analytics Integration</li>
    </ul>
  </div>

  <div class="border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow">
    <h2 class="text-2xl font-bold mb-4 text-gray-900">Business Systems</h2>
    <p class="text-gray-700 mb-4 leading-relaxed">
      Custom applications, CRM solutions, and workflow automation to streamline your operations and boost productivity.
    </p>
    <ul class="text-gray-600 space-y-2 text-sm">
      <li>✓ Custom Software Development</li>
      <li>✓ CRM & ERP Integration</li>
      <li>✓ Workflow Automation</li>
      <li>✓ Data Integration</li>
    </ul>
  </div>

  <div class="border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow">
    <h2 class="text-2xl font-bold mb-4 text-gray-900">Cloud Infrastructure</h2>
    <p class="text-gray-700 mb-4 leading-relaxed">
      Containerized solutions, deployment pipelines, and scalable architecture designed for reliability and growth.
    </p>
    <ul class="text-gray-600 space-y-2 text-sm">
      <li>✓ Docker & Kubernetes</li>
      <li>✓ CI/CD Pipelines</li>
      <li>✓ Cloud Architecture</li>
      <li>✓ DevOps Solutions</li>
    </ul>
  </div>
</div>

<div class="bg-gray-50 p-8 rounded-lg">
  <h2 class="text-2xl font-bold mb-6 text-gray-900">Our Process</h2>
  <div class="grid md:grid-cols-4 gap-6">
    <div class="text-center">
      <div class="bg-blue-600 text-white w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 font-bold text-lg">1</div>
      <h3 class="font-semibold text-gray-900 mb-2">Discovery</h3>
      <p class="text-gray-600 text-sm">We understand your business goals and requirements.</p>
    </div>
    <div class="text-center">
      <div class="bg-blue-600 text-white w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 font-bold text-lg">2</div>
      <h3 class="font-semibold text-gray-900 mb-2">Design</h3>
      <p class="text-gray-600 text-sm">We create solutions tailored to your unique needs.</p>
    </div>
    <div class="text-center">
      <div class="bg-blue-600 text-white w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 font-bold text-lg">3</div>
      <h3 class="font-semibold text-gray-900 mb-2">Development</h3>
      <p class="text-gray-600 text-sm">Professional execution with quality and best practices.</p>
    </div>
    <div class="text-center">
      <div class="bg-blue-600 text-white w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 font-bold text-lg">4</div>
      <h3 class="font-semibold text-gray-900 mb-2">Support</h3>
      <p class="text-gray-600 text-sm">Ongoing maintenance and support for success.</p>
    </div>
  </div>
</div>

</MainLayout>