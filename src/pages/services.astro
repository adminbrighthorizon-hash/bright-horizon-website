---
import MainLayout from "../layouts/MainLayout.astro";
import ServiceSection from "../components/ServiceSection.astro";
---

<MainLayout
  title="Services | Bright Horizon"
  description="Five pillars of service from IT and security to opportunity, travel, and trade facilitation."
>
<section class="soft-gradient border-b border-[#1F7A63]/10">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <h1 class="animate-fade-up text-4xl font-bold text-[#145A46] md:text-5xl">Services Built for Execution</h1>
    <p class="animate-fade-up animate-delay-1 mt-4 max-w-3xl text-lg text-[#1A1A1A]/85">
      End-to-end delivery for Startups and SMEs, from technology capability to market execution with measurable outcomes.
    </p>
  </div>
</section>

<section class="mx-auto grid max-w-6xl gap-6 px-6 py-16 md:grid-cols-2">
  <ServiceSection
    title="IT & Cloud"
    summary="Custom software development, ERP implementation, system integration, and cloud infrastructure for businesses scaling in Africa."
    items={["System integration", "Cloud solutions", "Web design"]}
  />
  <ServiceSection
    title="IAM & Security"
    summary="Information and cloud security with identity governance, risk control, compliance alignment, and penetration testing."
    items={["Identity governance", "Access control", "Security frameworks"]}
  />
  <ServiceSection
    title="Automation & Reporting"
    summary="Process automation, API-driven orchestration, and reporting dashboards that improve control, speed, and visibility."
    items={["Workflow automation", "API integrations", "Reporting dashboards"]}
  />
  <ServiceSection
    title="Digital Services"
    summary="Operational services and consulting for continuity, compliance, and execution support in fast-moving environments."
    items={["SSL certificate renewals", "Software license management", "Consulting services"]}
  />
</section>

<section class="mx-auto max-w-6xl px-6 pb-20">
  <div class="section-shell animate-fade-up p-10 text-center">
    <h2 class="text-3xl font-semibold text-[#145A46]">Technology Capability. Market Execution. African Insight.</h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm text-[#1A1A1A]/80">
      Full-stack IT, cybersecurity-first delivery, and practical execution support across South Africa, DRC, and the region.
    </p>
    <a
      href="https://portal.brighthorizon.co.za/solutions"
      target="_blank"
      rel="noreferrer"
      class="btn-primary mt-7 inline-flex rounded-full px-6 py-3 text-sm font-semibold"
    >
      Visit Solutions Portal
    </a>
  </div>
</section>
</MainLayout>
