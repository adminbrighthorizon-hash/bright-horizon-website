---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Services | Bright Horizon — Technology Solutions for Business Growth"
  description="IT services South Africa: Startup Launch Packs, CRM & Growth Systems, Tourism website solutions, ERP, Strategic Partnerships, and managed hosting. Starts from R299/month."
>

<!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
<section class="soft-gradient border-b border-[#1F7A63]/10">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <p class="animate-fade-up text-sm font-semibold uppercase tracking-[0.16em] text-[#175247]">Technology Services — South Africa</p>
    <h1 class="animate-fade-up animate-delay-1 mt-4 max-w-4xl text-4xl font-bold leading-tight text-[#103B34] md:text-6xl">
      Six Ways We Help Your Business Grow
    </h1>
    <p class="animate-fade-up animate-delay-2 mt-6 max-w-2xl text-lg text-[#1A1A1A]/80">
      From launching your first professional website to scaling enterprise systems and unlocking strategic partnerships — we have a solution built for where your business is today, and where it's heading.
    </p>
    <div class="animate-fade-up animate-delay-3 mt-8 flex flex-wrap gap-3">
      <a
        href="https://www.brighthorizon.co.za/contact/"
        target="_blank" rel="noreferrer"
        class="btn-primary btn-shine inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Book a Consultation
      </a>
      <a
        href="https://www.brighthorizon.co.za/contact/"
        target="_blank" rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-[#1F7A63]/40 px-6 py-3 text-sm font-semibold text-[#145A46] transition hover:bg-[#1F7A63]/8"
      >
        Request a Proposal
      </a>
    </div>
  </div>
</section>

<!-- ─── 6 SERVICE PACKS ───────────────────────────────────────────────────── -->
<section class="mx-auto max-w-6xl px-6 py-20">
  <div class="mb-12 text-center">
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#C79C49]">What We Offer</p>
    <h2 class="mt-2 text-3xl font-bold text-[#103B34] md:text-4xl">Structured Solutions for Every Stage of Growth</h2>
    <p class="mx-auto mt-3 max-w-2xl text-[#1A1A1A]/70">Choose the pack that fits your business today — or combine services to build a complete growth system tailored to your goals.</p>
  </div>

  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">

    <!-- 01 — Enterprise Operations Pack -->
    <div class="section-shell animate-fade-up flex flex-col p-8">
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#E8F4F0]">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1F7A63" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
      </div>
      <p class="mb-1 text-[0.65rem] font-bold uppercase tracking-[0.16em] text-[#1F7A63]">Pack 01</p>
      <h3 class="text-xl font-bold text-[#103B34]">Enterprise Operations Pack</h3>
      <p class="mt-2 flex-1 text-sm leading-relaxed text-[#1A1A1A]/70">Scale operations with integrated ERP-grade business systems. Built for established businesses that need dedicated infrastructure and full operational visibility.</p>
      <ul class="mt-4 space-y-2 text-sm text-[#1A1A1A]/75">
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> ERP systems (Odoo &amp; custom)</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Inventory &amp; purchasing workflows</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> HR basics &amp; payroll integration</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Advanced reporting &amp; dashboards</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Dedicated cloud infrastructure</li>
      </ul>
      <a href="https://www.brighthorizon.co.za/contact/" target="_blank" rel="noreferrer"
        class="mt-6 inline-flex justify-center rounded-full border border-[#1F7A63]/40 px-5 py-2.5 text-sm font-semibold text-[#145A46] transition hover:bg-[#1F7A63]/8">
        Request Proposal
      </a>
    </div>

    <!-- 02 — Growth Systems Pack -->
    <div class="section-shell animate-fade-up flex flex-col p-8" style="animation-delay:0.07s">
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#E8F4F0]">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1F7A63" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
      </div>
      <p class="mb-1 text-[0.65rem] font-bold uppercase tracking-[0.16em] text-[#1F7A63]">Pack 02</p>
      <h3 class="text-xl font-bold text-[#103B34]">Growth Systems Pack</h3>
      <p class="mt-2 flex-1 text-sm leading-relaxed text-[#1A1A1A]/70">Turn leads into customers and streamline your operations. Built for growing SMEs that need a connected system — not a patchwork of disconnected tools.</p>
      <ul class="mt-4 space-y-2 text-sm text-[#1A1A1A]/75">
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> CRM &amp; lead pipeline management</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Quotations &amp; invoicing</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Workflow automation</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Business dashboards &amp; reporting</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Dedicated ongoing support</li>
      </ul>
      <a href="https://www.brighthorizon.co.za/contact/" target="_blank" rel="noreferrer"
        class="btn-primary mt-6 inline-flex justify-center rounded-full px-5 py-2.5 text-sm font-semibold">
        Grow My Business
      </a>
    </div>

    <!-- 03 — Startup Launch Pack -->
    <div class="section-shell animate-fade-up flex flex-col p-8" style="animation-delay:0.14s">
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#E8F4F0]">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1F7A63" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      </div>
      <p class="mb-1 text-[0.65rem] font-bold uppercase tracking-[0.16em] text-[#1F7A63]">Pack 03</p>
      <h3 class="text-xl font-bold text-[#103B34]">Startup Launch Pack</h3>
      <p class="mt-2 flex-1 text-sm leading-relaxed text-[#1A1A1A]/70">Launch your business professionally and start attracting customers from day one. Everything you need to establish a credible, secure digital presence.</p>
      <ul class="mt-4 space-y-2 text-sm text-[#1A1A1A]/75">
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Professional business website</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Business email setup</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Secure managed hosting &amp; SSL</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Contact &amp; lead capture forms</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Monthly support &amp; updates</li>
      </ul>
      <a href="https://www.brighthorizon.co.za/contact/" target="_blank" rel="noreferrer"
        class="mt-6 inline-flex justify-center rounded-full border border-[#1F7A63]/40 px-5 py-2.5 text-sm font-semibold text-[#145A46] transition hover:bg-[#1F7A63]/8">
        Get Started
      </a>
    </div>

    <!-- 04 — Tourism & Travel Growth Pack -->
    <div class="section-shell animate-fade-up flex flex-col p-8" style="animation-delay:0.21s">
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FDF6E8]">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#C79C49" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      </div>
      <p class="mb-1 text-[0.65rem] font-bold uppercase tracking-[0.16em] text-[#C79C49]">Pack 04</p>
      <h3 class="text-xl font-bold text-[#103B34]">Tourism &amp; Travel Growth Pack</h3>
      <p class="mt-2 flex-1 text-sm leading-relaxed text-[#1A1A1A]/70">Increase bookings and manage travellers professionally. Built for travel agencies, lodges, tour operators, and shuttle services ready to grow online.</p>
      <ul class="mt-4 space-y-2 text-sm text-[#1A1A1A]/75">
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#C79C49]">✓</span> Booking &amp; enquiry website</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#C79C49]">✓</span> Lead capture &amp; traveller CRM</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#C79C49]">✓</span> Customer follow-up automation</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#C79C49]">✓</span> Online presence management</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#C79C49]">✓</span> Tour &amp; package showcasing</li>
      </ul>
      <a href="https://www.brighthorizon.co.za/contact/" target="_blank" rel="noreferrer"
        class="mt-6 inline-flex justify-center rounded-full border border-[#C79C49]/40 px-5 py-2.5 text-sm font-semibold text-[#6A4917] transition hover:bg-[#C79C49]/8">
        Book Consultation
      </a>
    </div>

    <!-- 05 — Strategic Partnership Pack -->
    <div class="section-shell animate-fade-up flex flex-col p-8" style="animation-delay:0.28s">
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#FDF6E8]">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#C79C49" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <p class="mb-1 text-[0.65rem] font-bold uppercase tracking-[0.16em] text-[#C79C49]">Pack 05</p>
      <h3 class="text-xl font-bold text-[#103B34]">Strategic Partnership Pack</h3>
      <p class="mt-2 flex-1 text-sm leading-relaxed text-[#1A1A1A]/70">Unlock new opportunities through strategic business connections. For businesses seeking expansion into new sectors, markets, or commercial partnerships.</p>
      <ul class="mt-4 space-y-2 text-sm text-[#1A1A1A]/75">
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#C79C49]">✓</span> Partnership sourcing &amp; introductions</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#C79C49]">✓</span> Commercial facilitation</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#C79C49]">✓</span> Growth strategy &amp; planning</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#C79C49]">✓</span> Vendor &amp; supplier introductions</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#C79C49]">✓</span> Cross-industry opportunities</li>
      </ul>
      <a href="https://www.brighthorizon.co.za/contact/" target="_blank" rel="noreferrer"
        class="mt-6 inline-flex justify-center rounded-full border border-[#C79C49]/40 px-5 py-2.5 text-sm font-semibold text-[#6A4917] transition hover:bg-[#C79C49]/8">
        Start the Conversation
      </a>
    </div>

    <!-- 06 — Student & Skills Pack -->
    <div class="section-shell animate-fade-up flex flex-col p-8" style="animation-delay:0.35s">
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#E8F4F0]">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1F7A63" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
      </div>
      <p class="mb-1 text-[0.65rem] font-bold uppercase tracking-[0.16em] text-[#1F7A63]">Pack 06</p>
      <h3 class="text-xl font-bold text-[#103B34]">Student &amp; Skills Pack</h3>
      <p class="mt-2 flex-1 text-sm leading-relaxed text-[#1A1A1A]/70">Build skills and launch your future. Designed for students, freelancers, and learners who need a real-world environment to practise, build, and grow.</p>
      <ul class="mt-4 space-y-2 text-sm text-[#1A1A1A]/75">
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Sandbox &amp; dev hosting environments</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Practice business systems</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Learning tools &amp; resources</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Starter website setup</li>
        <li class="flex items-start gap-2"><span class="mt-0.5 font-bold text-[#1F7A63]">✓</span> Mentorship pathway access</li>
      </ul>
      <a href="https://www.brighthorizon.co.za/contact/" target="_blank" rel="noreferrer"
        class="mt-6 inline-flex justify-center rounded-full border border-[#1F7A63]/40 px-5 py-2.5 text-sm font-semibold text-[#145A46] transition hover:bg-[#1F7A63]/8">
        Get Started
      </a>
    </div>

  </div>
</section>


<!-- ─── SME PRICING ───────────────────────────────────────────────────────── -->
<section class="py-20" style="background: linear-gradient(160deg, #fffcf5 0%, #fdf4e0 55%, #fef9ef 100%); border-top: 1px solid rgba(199,156,73,0.18); border-bottom: 1px solid rgba(199,156,73,0.18);">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-12 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-[#C79C49]/40 bg-[#C79C49]/10 px-3.5 py-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-[#C79C49]" style="box-shadow: 0 0 5px rgba(199,156,73,0.7);"></span>
          <span class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-[#6A4917]">SME Monthly Plans</span>
        </div>
        <h2 class="text-3xl font-bold text-[#103B34] md:text-4xl">Affordable Business Operating Systems</h2>
        <p class="mt-3 max-w-2xl text-[#1A1A1A]/70">
          Ready-to-use monthly platforms for South African small businesses. Enterprise-grade operations without the enterprise price tag. No IT team required.
        </p>
      </div>
    </div>

    <!-- Pricing Cards -->
    <div class="grid gap-6 md:grid-cols-3">
      <!-- Starter -->
      <div class="flex flex-col rounded-3xl border border-[#C79C49]/25 bg-white p-8 shadow-sm">
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#6A4917]">Starter Business OS</p>
        <p class="mt-2 text-3xl font-extrabold text-[#103B34]">R299<span class="text-base font-semibold text-[#1A1A1A]/50">/month</span></p>
        <p class="mt-1 text-xs text-[#1A1A1A]/50">From — pricing based on users</p>
        <div class="my-6 h-px bg-[#C79C49]/15"></div>
        <ul class="flex-1 space-y-3 text-sm text-[#1A1A1A]/80">
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> Point of Sale</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> Basic Inventory</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> Invoicing</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> Team Chat</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> Basic Reporting</li>
        </ul>
        <a href="https://www.brighthorizon.co.za/contact/" target="_blank" rel="noreferrer" class="mt-7 inline-flex justify-center rounded-full border border-[#1F7A63]/40 px-5 py-2.5 text-sm font-semibold text-[#145A46] transition hover:bg-[#1F7A63]/8">
          Get Started
        </a>
      </div>

      <!-- Growth — highlighted -->
      <div class="flex flex-col rounded-3xl border border-[#1F7A63]/30 bg-white p-8 shadow-md" style="box-shadow: 0 16px 48px -20px rgba(31,122,99,0.22); position: relative; overflow: hidden;">
        <div class="absolute inset-x-0 top-0 h-1 rounded-t-3xl" style="background: linear-gradient(90deg, #1F7A63, #C79C49);"></div>
        <div class="mb-3 inline-flex self-start items-center gap-1.5 rounded-full bg-[#1F7A63]/10 px-2.5 py-1">
          <span class="text-[0.65rem] font-bold uppercase tracking-wider text-[#175247]">Most Popular</span>
        </div>
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#175247]">Growth Business OS</p>
        <p class="mt-2 text-3xl font-extrabold text-[#103B34]">R799<span class="text-base font-semibold text-[#1A1A1A]/50">/month</span></p>
        <p class="mt-1 text-xs text-[#1A1A1A]/50">From — pricing based on users</p>
        <div class="my-6 h-px bg-[#1F7A63]/15"></div>
        <ul class="flex-1 space-y-3 text-sm text-[#1A1A1A]/80">
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> Everything in Starter</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> CRM</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> Purchasing</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> Customer Database</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> Advanced Reporting</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-[#1F7A63]">✓</span> Process Controls</li>
        </ul>
        <a href="https://www.brighthorizon.co.za/contact/" target="_blank" rel="noreferrer" class="btn-primary mt-7 inline-flex justify-center rounded-full px-5 py-2.5 text-sm font-semibold">
          Get Started
        </a>
