<!-- ─── SECTION 4: IT ADVISORY & TRANSFORMATION ──────────────────────────── -->
<section class="mx-auto max-w-6xl px-6 py-20">
  <div class="mb-10">
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#C79C49]">Section 04</p>
    <h2 class="mt-2 text-3xl font-bold text-[#103B34] md:text-4xl">Strategic Technology Advisory</h2>
    <p class="mt-3 max-w-2xl text-[#1A1A1A]/70">Business-first technology strategy for companies that need more than implementation. We help you plan, prioritise, and execute digital transformation aligned to your growth goals.</p>
  </div>
  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
