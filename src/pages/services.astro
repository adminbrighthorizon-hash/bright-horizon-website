---
import MainLayout from "../layouts/MainLayout.astro";
import ServiceSection from "../components/ServiceSection.astro";
---

<MainLayout
  title="Services | Bright Horizon"
  description="Six pillars of service from multi-cloud enablement and security to opportunity, travel, and trade facilitation."
>
<section class="soft-gradient border-b border-[#1F7A63]/10">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <h1 class="animate-fade-up text-4xl font-bold text-[#145A46] md:text-5xl">Services Built for Execution</h1>
    <p class="animate-fade-up animate-delay-1 mt-4 max-w-3xl text-lg text-[#1A1A1A]/85">
      Attractive, practical solutions for Startups and SMEs: from IT and cybersecurity to cross-border travel support and opportunity brokerage.
    </p>
  </div>
</section>

<section class="mx-auto grid max-w-6xl gap-6 px-6 py-16 md:grid-cols-2 xl:grid-cols-3">
  <ServiceSection
    title="IT & Cloud"
    image="https://images.unsplash.com/photo-1461749280684-dccba630e2f6?auto=format&fit=crop&w=1400&q=80"
    summary="Build a resilient digital backbone with tailored systems, cloud architecture, and implementation support that grows with your business across any major cloud platform."
    items={["Custom software and web platforms", "ERP and business systems rollout", "Multi-cloud migration and optimisation (AWS, Azure, GCP, OCI)"]}
  />
  <ServiceSection
    title="Cloud Enablement"
    image="https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=1400&q=80"
    summary="We guide students, developers, and startups in setting up and using free-tier cloud environments across AWS, Azure, Google Cloud, and Oracle Cloud, enabling hands-on experience without upfront infrastructure costs."
    items={["AWS Free Tier onboarding and setup", "Microsoft Azure Free Account configuration", "Google Cloud free credits and starter setup", "Oracle Cloud Always Free environment setup", "MFA and IAM security baseline across providers", "Basic VM provisioning and guided deployment labs"]}
  />
  <ServiceSection
    title="IAM & Security"
    image="https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=1400&q=80"
    summary="Protect identities, systems, and data using governance-first security strategies aligned to compliance and operational risk controls."
    items={["Identity governance and lifecycle", "Access control and policy enforcement", "Security baselines and advisory"]}
  />
  <ServiceSection
    title="Automation & Reporting"
    image="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1400&q=80"
    summary="Increase speed and visibility with automated workflows and reporting systems that turn operations into measurable outcomes."
    items={["Workflow and approval automation", "API integrations across platforms", "Executive and operational dashboards"]}
  />
  <ServiceSection
    title="Digital Services"
    image="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1400&q=80"
    summary="Keep your environment stable and compliant with managed digital operations support and practical technical consulting."
    items={["SSL certificate and domain operations", "Software license management", "Advisory and implementation consulting"]}
  />
  <ServiceSection
    title="Opportunity Brokerage"
    image="https://images.unsplash.com/photo-1557804506-669a67965ba0?auto=format&fit=crop&w=1400&q=80"
    summary="Connect to vetted strategic opportunities through regional market insight, partner facilitation, and deal-readiness support."
    items={["Partnership and market-entry facilitation", "Opportunity sourcing and qualification", "Execution planning for growth initiatives"]}
  />
  <ServiceSection
    title="Travel & Trade Facilitation"
    image="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&w=1400&q=80"
    summary="Enable smoother cross-border business movement with structured travel planning and trade execution support."
    items={["Business travel coordination", "Trade and logistics support", "Cross-border execution assistance"]}
  />
</section>

<section class="mx-auto max-w-6xl px-6 pb-20">
  <div class="section-shell animate-fade-up p-10 text-center">
    <h2 class="text-3xl font-semibold text-[#145A46]">Multi-Cloud Enablement. Market Execution. African Insight.</h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm text-[#1A1A1A]/80">
      Our platform is designed to be cloud-agnostic, supporting AWS, Azure, Google Cloud, and Oracle Cloud environments depending on user needs, cost, and scalability requirements.
    </p>
    <a
      href="https://www.brighthorizon.co.za/services/"
      target="_blank"
      rel="noreferrer"
      class="btn-primary mt-7 inline-flex rounded-full px-6 py-3 text-sm font-semibold"
    >
      Visit Solutions Portal
    </a>
  </div>
</section>
</MainLayout>
