---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>

<h1 class="text-5xl font-bold mb-4 text-gray-900">Our Work</h1>
<p class="text-xl text-gray-600 mb-12 max-w-2xl">Explore some of the digital solutions we've built for our clients.</p>

<div class="grid md:grid-cols-2 gap-8">
  
  <div class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
    <div class="bg-gradient-to-br from-blue-500 to-blue-600 h-48"></div>
    <div class="p-6">
      <h3 class="text-2xl font-bold text-gray-900 mb-2">E-Commerce Platform</h3>
      <p class="text-gray-600 mb-4">
        Built a modern, high-performance e-commerce platform with inventory management and payment integration for a growing retail business.
      </p>
      <div class="flex gap-2 flex-wrap">
        <span class="text-xs bg-blue-100 text-blue-700 px-3 py-1 rounded-full">React</span>
        <span class="text-xs bg-blue-100 text-blue-700 px-3 py-1 rounded-full">Node.js</span>
        <span class="text-xs bg-blue-100 text-blue-700 px-3 py-1 rounded-full">PostgreSQL</span>
      </div>
    </div>
  </div>

  <div class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
    <div class="bg-gradient-to-br from-purple-500 to-purple-600 h-48"></div>
    <div class="p-6">
      <h3 class="text-2xl font-bold text-gray-900 mb-2">SaaS Dashboard</h3>
      <p class="text-gray-600 mb-4">
        Developed a comprehensive analytics dashboard for a SaaS company, featuring real-time data visualization and user management.
      </p>
      <div class="flex gap-2 flex-wrap">
        <span class="text-xs bg-purple-100 text-purple-700 px-3 py-1 rounded-full">Vue.js</span>
        <span class="text-xs bg-purple-100 text-purple-700 px-3 py-1 rounded-full">Python</span>
        <span class="text-xs bg-purple-100 text-purple-700 px-3 py-1 rounded-full">Docker</span>
      </div>
    </div>
  </div>

  <div class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
    <div class="bg-gradient-to-br from-green-500 to-green-600 h-48"></div>
    <div class="p-6">
      <h3 class="text-2xl font-bold text-gray-900 mb-2">Business Management System</h3>
      <p class="text-gray-600 mb-4">
        Created a custom business management system with CRM, project tracking, and financial reporting for an enterprise client.
      </p>
      <div class="flex gap-2 flex-wrap">
        <span class="text-xs bg-green-100 text-green-700 px-3 py-1 rounded-full">C#/.NET</span>
        <span class="text-xs bg-green-100 text-green-700 px-3 py-1 rounded-full">SQL Server</span>
        <span class="text-xs bg-green-100 text-green-700 px-3 py-1 rounded-full">Azure</span>
      </div>
    </div>
  </div>

  <div class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
    <div class="bg-gradient-to-br from-orange-500 to-orange-600 h-48"></div>
    <div class="p-6">
      <h3 class="text-2xl font-bold text-gray-900 mb-2">Corporate Website Redesign</h3>
      <p class="text-gray-600 mb-4">
        Redesigned and rebuilt a corporate website with improved performance, modern design, and better user experience.
      </p>
      <div class="flex gap-2 flex-wrap">
        <span class="text-xs bg-orange-100 text-orange-700 px-3 py-1 rounded-full">Astro</span>
        <span class="text-xs bg-orange-100 text-orange-700 px-3 py-1 rounded-full">Tailwind CSS</span>
        <span class="text-xs bg-orange-100 text-orange-700 px-3 py-1 rounded-full">SEO</span>
      </div>
    </div>
  </div>

</div>

<section class="mt-16 bg-blue-50 p-12 rounded-lg border border-blue-100">
  <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Ready to Start Your Project?</h2>
  <p class="text-lg text-gray-700 text-center mb-8 max-w-2xl mx-auto">
    Let's work together to bring your vision to life. Contact us today to discuss your project and see how we can help you succeed.
  </p>
  <div class="text-center">
    <a
      href="/contact"
      class="inline-block bg-blue-600 text-white px-8 py-4 rounded-lg hover:bg-blue-700 font-semibold transition-colors"
    >
      Start Your Project
    </a>
  </div>
</section>

</MainLayout>