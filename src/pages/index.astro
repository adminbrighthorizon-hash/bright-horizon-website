---
import MainLayout from "../layouts/MainLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import OpportunityCard from "../components/OpportunityCard.astro";

const baseUrl = import.meta.env.BASE_URL;
const heroSlideFiles = [
  "photo-1504384308090-c894fdcc538d.avif",
  "photo-1561883088-039e53143d73.avif",
  "photo-1601926495045-d066ccae8085.avif",
  "premium_photo-1733306493254-52b143296396.avif",
  "premium_photo-1770404438404-4b3d10563f13.avif",
  "premium_photo-1770631480572-034749b312f0.avif"
];
const heroSlides = heroSlideFiles.map((file) => `${baseUrl}hero-slides/${file}`);
const heroSlideDurationSec = heroSlides.length * 7;
---

<MainLayout
  title="Bright Horizon | Where Technology Meets Opportunity"
  description="Technology. Security. African Opportunity. IT consulting for Startups and SMEs scaling across Africa."
>
<section
  class="cinematic-bg hero-overlay hero-interactive relative overflow-hidden border-b border-[#B38A4A]/20"
>
  <div class="hero-slideshow" style={`--hero-cycle: ${heroSlideDurationSec}s;`} aria-hidden="true">
    {
      heroSlides.map((slide, index) => (
        <span
          class="hero-slide"
          style={`--hero-image: url('${slide}'); --hero-delay: -${index * 7}s;`}
        ></span>
      ))
    }
  </div>
  <span class="floating-orb left-[8%] top-20 h-16 w-16 bg-[#B38A4A]/35"></span>
  <span class="floating-orb right-[10%] top-36 h-24 w-24 bg-[#FBF8F2]/25" style="animation-delay: 1.5s;"></span>
  <span class="floating-orb bottom-12 left-[45%] h-12 w-12 bg-[#164C43]/35" style="animation-delay: 2.2s;"></span>
  <span class="floating-orb right-[28%] bottom-18 h-20 w-20 bg-[#E0B867]/20" style="animation-delay: 0.8s;"></span>
  <span class="floating-orb left-[26%] bottom-10 h-14 w-14 bg-[#FFF4D8]/18" style="animation-delay: 1.9s;"></span>
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
    <div class="glass-surface max-w-3xl rounded-3xl p-8 shadow-2xl shadow-[#103B34]/30 md:p-10">
      <p class="animate-fade-up text-sm font-semibold uppercase tracking-[0.16em] text-[#164C43]">Bright Horizon - Africa</p>
      <h1 class="animate-fade-up animate-delay-1 mt-4 text-4xl font-bold leading-tight text-[#103B34] md:text-6xl">
        Technology. Security. African Opportunity.
      </h1>
      <p class="animate-fade-up animate-delay-2 mt-6 text-lg text-[#1A1A1A]/85 md:text-xl">
        Built for Startups and SMEs: practical IT consulting, information security, and opportunity facilitation across Africa's fastest-growing markets.
      </p>
      <div class="animate-fade-up animate-delay-2 mt-5 flex flex-wrap gap-2">
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Johannesburg</span>
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Kinshasa</span>
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Kolwezi</span>
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Lubumbashi</span>
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Cape Town</span>
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Nairobi</span>
      </div>
      <div class="animate-fade-up animate-delay-3 mt-10 flex flex-wrap gap-4">
        <a
          href="https://dev.brighthorizon.co.za/contactus"
          target="_blank"
          rel="noreferrer"
          class="hero-cta-primary btn-shine rounded-full px-6 py-3 text-sm font-semibold"
        >
          Get Started
        </a>
        <a href={`${baseUrl}services`} class="hero-cta-secondary btn-shine rounded-full px-6 py-3 text-sm font-semibold">
          Our Services
        </a>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-6 py-20">
  <h2 class="animate-fade-up text-3xl font-semibold text-[#145A46] md:text-4xl">Five Pillars of Service</h2>
  <p class="animate-fade-up animate-delay-1 mt-3 max-w-3xl text-[#1A1A1A]/80">
    End-to-end solutions from technology to opportunity, designed for growth-stage Startups and ambitious SMEs.
  </p>
  <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
    <ServiceCard title="IT Services" icon="💻" description="Custom software development, ERP implementation, cloud infrastructure, and managed IT support." />
    <ServiceCard title="Information & Cloud Security" icon="🔐" description="Security, cloud protection, integration, automation, POPIA/GDPR compliance, and pen testing." />
    <ServiceCard title="Opportunity Brokerage" icon="🤝" description="Curated investment, trade, and partnership opportunities across key African growth sectors." />
    <ServiceCard title="Travel & Trade Facilitation" icon="🌍" description="Business travel coordination, logistics support, and cross-border facilitation for execution." />
  </div>
</section>

<section class="mx-auto max-w-6xl px-6 pb-8">
  <div class="section-shell soft-gradient animate-fade-up p-10 text-center">
    <h2 class="text-3xl font-semibold text-[#145A46]">Explore Our Solutions & Packages</h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm text-[#1A1A1A]/80">
      We do not just advise - we execute, connect, and deliver through structured service packages.
    </p>
    <a
      href="https://portal.brighthorizon.co.za/solutions"
      target="_blank"
      rel="noreferrer"
      class="btn-primary btn-shine mt-7 inline-flex rounded-full px-6 py-3 text-sm font-semibold"
    >
      Explore Solutions
    </a>
  </div>
</section>

<section class="mx-auto max-w-6xl px-6 py-16">
  <h2 class="animate-fade-up text-3xl font-semibold text-[#103B34] md:text-4xl">Sectors We Operate In</h2>
  <p class="animate-fade-up animate-delay-1 mt-3 max-w-3xl text-[#1A1A1A]/80">
    We power industry growth with practical digital execution: secure connectivity, workflow automation, data visibility, and partner-ready operating models tailored to each market.
  </p>
  <div class="mt-10 grid gap-6 md:grid-cols-2">
    <OpportunityCard
      title="Kinshasa, DRC - Connected City & Enterprise Uplift"
      description="From fiber backbone to smart-service platforms, we help public and private operators launch resilient digital infrastructure that scales across institutions, campuses, and business districts."
      image="https://images.unsplash.com/photo-1465447142348-e9952c393450?auto=format&fit=crop&w=1400&q=80"
    />
    <OpportunityCard
      title="Kolwezi, DRC - Smart Cobalt & Copper Supply Networks"
      description="Digitally enabled mining ecosystems with traceability, supplier coordination, and production intelligence to improve throughput, compliance, and global partner confidence."
      image="https://images.unsplash.com/photo-1516937941344-00b4e0337589?auto=format&fit=crop&w=1400&q=75"
    />
    <OpportunityCard
      title="Lubumbashi, DRC - AgriTech Production & Processing Hubs"
      description="Mechanized farming meets digital operations: crop planning, post-harvest logistics, storage visibility, and export pipeline coordination for high-value agricultural output."
      image="https://images.unsplash.com/photo-1625246333195-78d9c38ad449?auto=format&fit=crop&w=1400&q=80"
    />
    <OpportunityCard
      title="Cape Town, South Africa - Smart Property & Tourism Experiences"
      description="Technology-led property and tourism initiatives with digital booking flows, analytics-driven operations, and secure customer engagement to increase occupancy, spend, and repeat visits."
      image="https://images.unsplash.com/photo-1576485290814-1c72aa4bbb8e?auto=format&fit=crop&w=1400&q=75"
    />
    <OpportunityCard
      title="Johannesburg, South Africa - FinTech Ops & Cyber Resilience"
      description="From digital onboarding to secure transaction workflows, we help fintech and enterprise teams modernize core operations with cloud platforms, compliance-ready controls, and automation that drives faster growth."
      image="https://images.unsplash.com/photo-1563013544-824ae1b704d3?auto=format&fit=crop&w=1400&q=80"
    />
    <OpportunityCard
      title="Nairobi, Kenya - Digital Commerce & Innovation Scale"
      description="We enable growth-stage ventures with API-first platforms, secure payment integrations, and data-driven operations that accelerate regional expansion across East Africa."
      image="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1400&q=80"
    />
  </div>
  <div class="mt-10 rounded-3xl border border-[#E1C178]/35 bg-gradient-to-r from-[#0E3D35]/95 via-[#135042]/95 to-[#0D3831]/95 p-7 shadow-2xl shadow-[#05201C]/30">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h3 class="text-xl font-semibold tracking-tight text-[#FFF2D1]">Regional Opportunity Focus</h3>
      <span class="rounded-full border border-[#E1C178]/45 bg-[#E1C178]/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-[#FFE7B5]">
        Active Markets
      </span>
    </div>
    <div class="mt-5 grid gap-2.5 text-sm md:grid-cols-2">
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Johannesburg - FinTech Ops & Cybersecurity</p>
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Kinshasa - Infrastructure & Digital Expansion</p>
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Lubumbashi - Agriculture & Processing Growth</p>
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Kolwezi - Mining & Supply Chain Opportunities</p>
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Cape Town - Property & Tourism Growth</p>
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Nairobi - Digital Commerce & Innovation Scale</p>
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-6 pb-20">
  <div class="section-shell animate-fade-up p-10 text-center">
    <h2 class="text-3xl font-semibold text-[#103B34]">Ready to Grow with Us?</h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm text-[#1A1A1A]/80">
      From cybersecurity and digital transformation to curated African opportunities, we help you move with confidence and speed.
    </p>
    <a
      href={`${baseUrl}contact`}
      class="btn-primary btn-shine mt-7 inline-flex rounded-full px-6 py-3 text-sm font-semibold"
    >
      Work With Us
    </a>
  </div>
</section>
</MainLayout>