---
import MainLayout from "../layouts/MainLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import OpportunityCard from "../components/OpportunityCard.astro";

const baseUrl = import.meta.env.BASE_URL;
const heroSlideFiles = [
  "photo-1504384308090-c894fdcc538d.avif",
  "photo-1561883088-039e53143d73.avif",
  "photo-1601926495045-d066ccae8085.avif",
  "premium_photo-1733306493254-52b143296396.avif",
  "premium_photo-1770404438404-4b3d10563f13.avif",
  "premium_photo-1770631480572-034749b312f0.avif"
];
const heroSlides = heroSlideFiles.map((file) => `${baseUrl}hero-slides/${file}`);
const heroSlideDurationSec = heroSlides.length * 7;
---

<MainLayout
  title="Bright Horizon | Technology Solutions for Business Growth"
  description="Bright Horizon is a trusted technology growth partner for businesses in South Africa. Cloud hosting, Odoo ERP, automation, IT consulting, and SME business solutions."
>
<section
  class="cinematic-bg hero-overlay hero-interactive relative min-h-[70vh] overflow-hidden border-b border-[#B38A4A]/20 md:min-h-[86vh]"
>
  <div class="hero-slideshow" style={`--hero-cycle: ${heroSlideDurationSec}s;`} aria-hidden="true">
    {
      heroSlides.map((slide, index) => (
        <span
          class="hero-slide"
          style={`--hero-image: url('${slide}'); --hero-delay: -${index * 7}s;`}
        ></span>
      ))
    }
  </div>
  <span class="floating-orb left-[8%] top-20 h-16 w-16 bg-[#B38A4A]/35"></span>
  <span class="floating-orb right-[10%] top-36 h-24 w-24 bg-[#FBF8F2]/25" style="animation-delay: 1.5s;"></span>
  <span class="floating-orb bottom-12 left-[45%] h-12 w-12 bg-[#164C43]/35" style="animation-delay: 2.2s;"></span>
  <span class="floating-orb right-[28%] bottom-18 h-20 w-20 bg-[#E0B867]/20" style="animation-delay: 0.8s;"></span>
  <span class="floating-orb left-[26%] bottom-10 h-14 w-14 bg-[#FFF4D8]/18" style="animation-delay: 1.9s;"></span>
  <div class="mx-auto flex h-full max-w-6xl items-end px-6 py-20 md:py-28">
  </div>
</section>

<section class="relative mx-auto max-w-6xl px-6 pb-8 pt-10 md:pb-10 md:pt-14">
  <div class="animate-fade-up overflow-hidden rounded-[1.9rem] border border-[#C79C49]/30 bg-linear-to-br from-[#fffaf1]/95 via-[#fff4de]/96 to-[#f4e7cd]/95 p-8 shadow-[0_34px_70px_-34px_rgba(10,35,31,0.72)] md:p-10">
    <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-[#C79C49]/10 blur-2xl"></div>
    <div class="absolute -bottom-8 -left-8 h-32 w-32 rounded-full bg-[#175247]/10 blur-2xl"></div>

    <div class="relative">
      <p class="mb-3 inline-flex rounded-full border border-[#E1C178]/45 bg-[#0E3D35]/8 px-3 py-1 text-[0.66rem] font-bold uppercase tracking-[0.14em] text-[#6A4917]">Trusted Technology Growth Partner</p>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[#6A4917]">Bright Horizon</p>
      <h1 class="mt-3 max-w-4xl text-3xl font-extrabold leading-tight tracking-tight text-[#103B34] md:text-5xl">
        Technology Solutions Built for Business Growth
      </h1>
      <div class="mt-5 h-0.5 w-14 rounded-full bg-linear-to-r from-[#c79c49] to-[#dabc84]"></div>
      <p class="mt-6 max-w-3xl text-base leading-relaxed text-[#1A1A1A]/80 md:text-lg">
        We help businesses reduce costs, improve productivity, and scale confidently through cloud systems, automation, managed hosting, and smart business technology.
      </p>

      <div class="mt-6 flex flex-wrap gap-2.5">
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Reduce Costs</span>
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Boost Productivity</span>
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Automate Operations</span>
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Scale Confidently</span>
        <span class="accent-chip rounded-full px-3 py-1 text-xs font-semibold">Modernise Systems</span>
      </div>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="https://cal.com/bright-horizon-apzin0/bright-horizon-consultation-requirements-use-case-discussion?overlayCalendar=true"
          target="_blank"
          rel="noreferrer"
          class="hero-cta-primary btn-shine rounded-full px-7 py-3.5 text-sm font-bold"
        >
          Book a Consultation
        </a>
        <a href={`${baseUrl}services`} class="hero-cta-secondary btn-shine rounded-full px-7 py-3.5 text-sm font-bold">
          Explore Services
        </a>
      </div>
    </div>
  </div>
</section>

<section class="py-20" style="background: linear-gradient(160deg, #0f3c34 0%, #175247 55%, #1a6358 100%);">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-12 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-[#C79C49]/35 px-4 py-1.5" style="background: rgba(199,156,73,0.12);">
        <span class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-[#e1c178]">Our Solutions</span>
      </div>
      <h2 class="animate-fade-up text-3xl font-extrabold tracking-tight text-[#fffaf1] md:text-4xl">What We Do Best</h2>
      <p class="animate-fade-up animate-delay-1 mx-auto mt-3 max-w-2xl text-base" style="color: rgba(215,234,229,0.75);">
        Practical technology solutions designed to reduce costs, improve efficiency, and give your business a competitive edge — from day one.
      </p>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <ServiceCard title="Enterprise Operations Pack" icon="🏢" description="ERP systems, inventory, HR basics, advanced reporting, and dedicated cloud infrastructure for established businesses that need full operational visibility." dark={true} number="01" />
      <ServiceCard title="Growth Systems Pack" icon="📈" description="CRM, lead pipeline, invoicing, workflow automation, and dashboards. Turn leads into customers and run your operations from one connected platform." dark={true} number="02" />
      <ServiceCard title="Startup Launch Pack" icon="🚀" description="Professional website, business email, secure hosting, SSL, and monthly support — everything to launch your business and start attracting customers." dark={true} number="03" />
      <ServiceCard title="Tourism & Travel Growth Pack" icon="🌍" description="Booking websites, traveller CRM, enquiry automation, and online presence management — built to increase bookings for agencies, lodges, and tour operators." dark={true} number="04" />
      <ServiceCard title="Strategic Partnership Pack" icon="🤝" description="Partnership sourcing, commercial facilitation, vendor introductions, and growth strategy for businesses seeking new markets, sectors, and opportunities." dark={true} number="05" />
      <ServiceCard title="Student & Skills Pack" icon="🎓" description="Sandbox hosting, practice systems, learning tools, and starter websites for students, freelancers, and learners building real-world skills." dark={true} number="06" />
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-6 pb-8">
  <div class="section-shell soft-gradient animate-fade-up p-10 text-center">
    <h2 class="text-3xl font-semibold text-[#145A46]">Ready to Build a Smarter Business?</h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm text-[#1A1A1A]/80">
      From managed cloud hosting in South Africa to affordable Odoo ERP and business automation — we execute with you, not just advise.
    </p>
    <a
      href={`${baseUrl}services`}
      class="btn-primary btn-shine mt-7 inline-flex rounded-full px-6 py-3 text-sm font-semibold"
    >
      See All Services
    </a>
  </div>
</section>

<!-- ── WHY BRIGHT HORIZON TRUST SECTION ──────────────────────────────── -->
<section class="border-y border-[#1F7A63]/8 bg-[#FAFDF9] py-20">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-12 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-[#C79C49]/35 bg-[#C79C49]/10 px-4 py-1.5">
        <span class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-[#6A4917]">Why Clients Choose Us</span>
      </div>
      <h2 class="animate-fade-up text-3xl font-extrabold tracking-tight text-[#103B34] md:text-4xl">Why Businesses Choose Bright Horizon</h2>
      <p class="animate-fade-up animate-delay-1 mx-auto mt-3 max-w-2xl text-base text-[#1A1A1A]/65">
        We don't just deliver technology — we invest in your growth. Here's what our clients tell us makes the difference.
      </p>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { icon: "🎯", title: "Business-First Approach", body: "We start with your business goals, not technology features. Every recommendation is tied to a measurable outcome." },
        { icon: "💡", title: "Practical Solutions with Real Value", body: "No bloated systems or unnecessary complexity. We design for what works now and scales with you over time." },
        { icon: "⚡", title: "Reliable Support & Fast Response", body: "South Africa-based support with fast turnaround. You speak to people who know your systems and your business." },
        { icon: "📐", title: "Scalable Systems Built for Growth", body: "Everything we build is designed to grow with you — from a 5-person startup to a multi-branch operation." },
        { icon: "💰", title: "Cost-Conscious Innovation", body: "We help you achieve more with your technology budget — reducing waste, automating manual work, and optimising spend." },
        { icon: "🤝", title: "Long-Term Partnership Mindset", body: "We measure success by your success. Our best client relationships span years, not projects." },
      ].map((item) => (
        <div class="section-shell animate-fade-up flex flex-col gap-3 p-7">
          <span class="text-2xl" aria-hidden="true">{item.icon}</span>
          <h3 class="font-bold text-[#103B34]">{item.title}</h3>
          <p class="text-sm leading-relaxed text-[#1A1A1A]/70">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-6 py-16">
  <h2 class="animate-fade-up text-3xl font-semibold text-[#103B34] md:text-4xl">Where We Create Impact</h2>
  <p class="animate-fade-up animate-delay-1 mt-3 max-w-3xl text-[#1A1A1A]/80">
    We operate across South Africa and key African markets — delivering technology solutions that improve productivity, reduce costs, and unlock growth in every sector we serve.
  </p>
  <div class="mt-10 grid gap-6 md:grid-cols-2">
    <OpportunityCard
      title="Johannesburg, South Africa - FinTech Ops & Cyber Resilience"
      description="From digital onboarding to secure transaction workflows, we help fintech and enterprise teams modernize core operations with cloud platforms, compliance-ready controls, and automation that drives faster growth."
      image="https://images.unsplash.com/photo-1563013544-824ae1b704d3?auto=format&fit=crop&w=1400&q=80"
    />
    <OpportunityCard
      title="Kinshasa, DRC - Connected City & Enterprise Uplift"
      description="From fiber backbone to smart-service platforms, we help public and private operators launch resilient digital infrastructure that scales across institutions, campuses, and business districts."
      image="https://images.unsplash.com/photo-1465447142348-e9952c393450?auto=format&fit=crop&w=1400&q=80"
    />
    <OpportunityCard
      title="Kolwezi, DRC - Smart Cobalt & Copper Supply Networks"
      description="Digitally enabled mining ecosystems with traceability, supplier coordination, and production intelligence to improve throughput, compliance, and global partner confidence."
      image="https://images.unsplash.com/photo-1516937941344-00b4e0337589?auto=format&fit=crop&w=1400&q=75"
    />
    <OpportunityCard
      title="Cape Town, South Africa - Smart Property & Tourism Experiences"
      description="Technology-led property and tourism initiatives with digital booking flows, analytics-driven operations, and secure customer engagement to increase occupancy, spend, and repeat visits."
      image="https://images.unsplash.com/photo-1576485290814-1c72aa4bbb8e?auto=format&fit=crop&w=1400&q=75"
    />
    <OpportunityCard
      title="Lubumbashi, DRC - AgriTech Production & Processing Hubs"
      description="Mechanized farming meets digital operations: crop planning, post-harvest logistics, storage visibility, and export pipeline coordination for high-value agricultural output."
      image="https://images.unsplash.com/photo-1625246333195-78d9c38ad449?auto=format&fit=crop&w=1400&q=80"
    />
    <OpportunityCard
      title="Nairobi, Kenya - Digital Commerce & Innovation Scale"
      description="We enable growth-stage ventures with API-first platforms, secure payment integrations, and data-driven operations that accelerate regional expansion across East Africa."
      image="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1400&q=80"
    />
  </div>
  <div class="mt-10 rounded-3xl border border-[#E1C178]/35 bg-linear-to-r from-[#0E3D35]/95 via-[#135042]/95 to-[#0D3831]/95 p-7 shadow-2xl shadow-[#05201C]/30">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h3 class="text-xl font-semibold tracking-tight text-[#FFF2D1]">Regional Opportunity Focus</h3>
      <span class="rounded-full border border-[#E1C178]/45 bg-[#E1C178]/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-[#FFE7B5]">
        Active Markets
      </span>
    </div>
    <div class="mt-5 grid gap-2.5 text-sm md:grid-cols-2">
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Johannesburg - FinTech Ops & Cyber Resilience</p>
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Kinshasa - Connected City & Enterprise Uplift</p>
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Kolwezi - Smart Cobalt & Copper Supply Networks</p>
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Cape Town - Smart Property & Tourism Experiences</p>
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Lubumbashi - AgriTech Production & Processing Hubs</p>
      <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Nairobi - Digital Commerce & Innovation Scale</p>
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-6 pb-20">
  <div class="section-shell animate-fade-up p-10 text-center">
    <h2 class="text-3xl font-semibold text-[#103B34]">Let's Grow Your Business Together</h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm text-[#1A1A1A]/80">
      Tell us your challenge. We'll bring the experience, the technology, and the commitment to help you achieve it.
    </p>
    <div class="mt-7 flex flex-wrap justify-center gap-3">
      <a
        href="https://cal.com/bright-horizon-apzin0/bright-horizon-consultation-requirements-use-case-discussion?overlayCalendar=true"
        target="_blank" rel="noreferrer"
        class="btn-primary btn-shine inline-flex rounded-full px-6 py-3 text-sm font-semibold"
      >
        Book a Discovery Call
      </a>
      <a
        href={`${baseUrl}contact`}
        class="inline-flex rounded-full border border-[#1F7A63]/35 px-6 py-3 text-sm font-semibold text-[#145A46] transition hover:bg-[#1F7A63]/8"
      >
        Speak to an Expert
      </a>
    </div>
  </div>
</section>
</MainLayout>