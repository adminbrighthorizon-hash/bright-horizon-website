---
import MainLayout from "../layouts/MainLayout.astro";

const baseUrl = import.meta.env.BASE_URL;
---

<MainLayout
  title="Solutions | Bright Horizon"
  description="Explore Bright Horizon solution packages across IT, security, automation, and market execution."
>
<section class="soft-gradient border-b border-[#1F7A63]/10">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <p class="text-sm font-semibold uppercase tracking-[0.14em] text-[#1F7A63]">Bright Horizon Solutions</p>
    <h1 class="mt-4 text-4xl font-bold text-[#145A46] md:text-5xl">Execution-Ready Solutions for Growth in Africa</h1>
    <p class="mt-4 max-w-3xl text-lg text-[#1A1A1A]/85">
      Practical, security-first solutions designed for Startups and SMEs that need results: better operations,
      stronger controls, and faster market execution.
    </p>
  </div>
</section>

<section class="mx-auto max-w-6xl px-6 py-16">
  <div class="grid gap-6 md:grid-cols-2">
    <article class="section-shell p-8">
      <h2 class="text-2xl font-semibold text-[#145A46]">IT & Cloud Foundations</h2>
      <p class="mt-3 text-sm text-[#1A1A1A]/85">
        Modernize and stabilize core systems with scalable cloud architecture, business systems, and integration.
      </p>
      <ul class="mt-4 space-y-2 text-sm text-[#1A1A1A]">
        <li>• Cloud setup and optimization</li>
        <li>• ERP and workflow integration</li>
        <li>• Managed support and continuity</li>
      </ul>
    </article>

    <article class="section-shell p-8">
      <h2 class="text-2xl font-semibold text-[#145A46]">IAM & Security Assurance</h2>
      <p class="mt-3 text-sm text-[#1A1A1A]/85">
        Protect identity, access, and data with governance-led controls and compliance-ready security practices.
      </p>
      <ul class="mt-4 space-y-2 text-sm text-[#1A1A1A]">
        <li>• Identity governance and access controls</li>
        <li>• Security baselines and hardening</li>
        <li>• Advisory and implementation support</li>
      </ul>
    </article>

    <article class="section-shell p-8">
      <h2 class="text-2xl font-semibold text-[#145A46]">Automation & Reporting</h2>
      <p class="mt-3 text-sm text-[#1A1A1A]/85">
        Reduce manual effort with integration and automation patterns that improve speed, visibility, and control.
      </p>
      <ul class="mt-4 space-y-2 text-sm text-[#1A1A1A]">
        <li>• Workflow and approval automation</li>
        <li>• API-led process integration</li>
        <li>• Operational and executive dashboards</li>
      </ul>
    </article>

    <article class="section-shell p-8">
      <h2 class="text-2xl font-semibold text-[#145A46]">Opportunity Enablement</h2>
      <p class="mt-3 text-sm text-[#1A1A1A]/85">
        Move from strategy to action with practical support for partnerships, trade flows, and regional expansion.
      </p>
      <ul class="mt-4 space-y-2 text-sm text-[#1A1A1A]">
        <li>• Opportunity mapping and facilitation</li>
        <li>• Cross-border operational support</li>
        <li>• Execution planning for market entry</li>
      </ul>
    </article>
  </div>
</section>

<section class="mx-auto max-w-6xl px-6 pb-20">
  <div class="section-shell p-10 text-center">
    <h2 class="text-3xl font-semibold text-[#145A46]">Need a Tailored Package?</h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm text-[#1A1A1A]/80">
      Tell us your priorities and we will align the right solution mix for your growth stage, team capacity, and target markets.
    </p>
    <a
      href={`${baseUrl}contact`}
      class="btn-primary btn-shine mt-7 inline-flex rounded-full px-6 py-3 text-sm font-semibold"
    >
      Discuss Your Requirements
    </a>
  </div>
</section>
</MainLayout>