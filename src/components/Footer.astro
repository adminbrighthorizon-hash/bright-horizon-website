---
import horizonLogo from "../assets/horizon-mark.svg";

const baseUrl = import.meta.env.BASE_URL;
---

<footer class="mt-20 bg-[#145A46] text-white">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="mb-12 grid gap-8 md:grid-cols-4">
      <div>
        <div class="flex items-center gap-4">
          <img src={horizonLogo.src} alt="Bright Horizon logo" class="logo-badge logo-badge--footer" loading="lazy" decoding="async" />
          <div class="brand-lockup brand-lockup--footer">
            <h3 class="brand-wordmark">Bright Horizon</h3>
            <p class="brand-tagline brand-tagline--footer">Technology. Security. Opportunity.</p>
          </div>
        </div>
        <p class="mt-5 text-[#E8F2EF]">
          Trusted consulting, secure digital delivery, and opportunity facilitation for organizations building with confidence across Africa.
        </p>
      </div>
      <div>
        <h4 class="mb-4 font-semibold">Services</h4>
        <ul class="space-y-2 text-[#D7EAE5]">
          <li><a href={`${baseUrl}services`} class="transition-colors hover:text-white">IT & Cloud Solutions</a></li>
          <li><a href={`${baseUrl}services`} class="transition-colors hover:text-white">IAM & Security</a></li>
          <li><a href={`${baseUrl}services`} class="transition-colors hover:text-white">Automation & Reporting</a></li>
        </ul>
      </div>
      <div>
        <h4 class="mb-4 font-semibold">Company</h4>
        <ul class="space-y-2 text-[#D7EAE5]">
          <li><a href={`${baseUrl}about`} class="transition-colors hover:text-white">About Us</a></li>
          <li><a href="https://portal.brighthorizon.co.za/solutions" target="_blank" rel="noreferrer" class="transition-colors hover:text-white">Solutions Portal</a></li>
          <li><a href={`${baseUrl}contact`} class="transition-colors hover:text-white">Work With Us</a></li>
        </ul>
      </div>
      <div>
        <h4 class="mb-4 font-semibold">Regions</h4>
        <p class="text-sm text-[#D7EAE5]">
          South Africa and Democratic Republic of Congo, with international collaboration and delivery.
        </p>
        <div class="mt-4 space-y-2 text-sm">
          <p>
            <a href="mailto:info@brighthorizon.co.za" class="transition-colors hover:text-white">info@brighthorizon.co.za</a>
          </p>
          <p>
            <a href="https://wa.me/27793599604" target="_blank" rel="noreferrer" class="transition-colors hover:text-white">WhatsApp: +27 79 359 9604</a>
          </p>
        </div>
      </div>
    </div>
    <div class="mb-12 rounded-3xl border border-[#E1C178]/35 bg-gradient-to-r from-[#0E3D35]/95 via-[#135042]/95 to-[#0D3831]/95 p-7 shadow-2xl shadow-[#05201C]/45">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h4 class="text-xl font-semibold tracking-tight text-[#FFF2D1]">Regional Opportunity Focus</h4>
        <span class="rounded-full border border-[#E1C178]/45 bg-[#E1C178]/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-[#FFE7B5]">
          Active Markets
        </span>
      </div>
      <div class="mt-5 grid gap-2.5 md:grid-cols-2 text-sm">
        <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Johannesburg - FinTech Ops & Cybersecurity</p>
        <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Kinshasa - Infrastructure & Digital Expansion</p>
        <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Katanga - Agriculture & Processing Growth</p>
        <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Lualaba - Mining & Supply Chain Opportunities</p>
        <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Cape Town - Property & Tourism Growth</p>
        <p class="rounded-xl border border-[#E1C178]/25 bg-[#0A2D27]/42 px-4 py-2.5 text-[#FFF6E2]">Nairobi - Digital Commerce & Innovation Scale</p>
      </div>
    </div>
    <div class="border-t border-white/20 pt-8 text-center text-sm text-[#D7EAE5]">
      <p>© 2026 Bright Horizon. All rights reserved.</p>
    </div>
  </div>
</footer>