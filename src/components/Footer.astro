---
import horizonLogo from "../assets/bh-logo.svg";

const baseUrl = import.meta.env.BASE_URL;
---

<footer class="mt-16 border-t border-[#0F4A3D]/20 bg-[#145A46] text-white">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-6 px-6 py-4">
    <div class="flex items-center gap-3">
      <img src={horizonLogo.src} alt="Bright Horizon logo" class="logo-badge logo-badge--footer" loading="lazy" decoding="async" />
      <div class="brand-lockup brand-lockup--footer">
        <span class="brand-wordmark">Bright Horizon</span>
        <span class="brand-tagline brand-tagline--footer">Technology. Security. Opportunity.</span>
      </div>
    </div>
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-[#D7EAE5]">
      <a href={`${baseUrl}services`} class="transition-colors hover:text-white">Services</a>
      <a href={`${baseUrl}about`} class="transition-colors hover:text-white">About</a>
      <a href={`${baseUrl}contact`} class="transition-colors hover:text-white">Contact</a>
      <a href="https://portal.brighthorizon.co.za/solutions" target="_blank" rel="noreferrer" class="transition-colors hover:text-white">Solutions Portal</a>
      <span class="hidden text-[#D7EAE5]/40 sm:inline">|</span>
      <a href="mailto:info@brighthorizon.co.za" class="font-semibold text-[#FFD97A] transition-colors hover:text-white">info@brighthorizon.co.za</a>
      <a href="tel:+278770021060" class="font-semibold text-[#FFD97A] transition-colors hover:text-white">+27 877 002 106</a>
    </div>
  </div>
  <div class="border-t border-[#0F4A3D]/30 px-6 py-2 text-center text-xs text-[#D7EAE5]/60">
    &copy; 2025 Bright Horizon. All rights reserved.
  </div>
</footer>