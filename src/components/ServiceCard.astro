---
interface Props {
  title: string;
  description: string;
  icon: string;
  dark?: boolean;
  number?: string;
}

const { title, description, icon, dark = false, number } = Astro.props;
---

<article class:list={["group overflow-hidden rounded-2xl border p-7", dark ? "border-white/10 text-white" : "section-shell animate-fade-up"]} style={dark ? "background: rgba(255,251,242,0.06); backdrop-filter: blur(4px);" : ""}>
  <div class="mb-4 flex items-start justify-between">
    <div class:list={["inline-flex h-12 w-12 items-center justify-center rounded-xl text-2xl", dark ? "bg-white/10" : "bg-[#1F7A63]/12 text-[#145A46]"]}>
      {icon}
    </div>
    {number && <span class:list={["text-xs font-bold uppercase tracking-[0.14em]", dark ? "text-[#FFD97A]/70" : "text-[#c79c49]"]}>{number}</span>}
  </div>
  <h3 class:list={["mb-2 text-xl font-semibold", dark ? "text-[#fffaf1]" : "text-[#145A46]"]}>{title}</h3>
  <p class:list={["text-sm leading-relaxed", dark ? "text-[#BBD8D1]" : "text-[#1A1A1A]/85"]}>{description}</p>
  <div class:list={["mt-5 h-0.5 w-0 rounded-full transition-all duration-300 group-hover:w-14", dark ? "bg-[#FFD97A]/60" : "bg-[#2E9C7E]"]}></div>
</article>
