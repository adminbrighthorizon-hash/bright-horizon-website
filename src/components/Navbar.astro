---
import horizonLogo from "../assets/horizon1.png";

const baseUrl = import.meta.env.BASE_URL;
---

<nav class="sticky top-0 z-50 border-b border-[#1F7A63]/10 bg-[#FAF7F2]/95 shadow-sm backdrop-blur-md">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-4">
    <a href={baseUrl} class="flex items-center gap-3 text-2xl font-bold tracking-tight transition-colors">
      <img src={horizonLogo.src} alt="Bright Horizon logo" class="h-10 w-10 rounded-md object-contain" loading="eager" decoding="async" />
      <span class="brand-wordmark">Bright Horizon</span>
    </a>

    <div class="hidden items-center gap-7 text-sm font-semibold md:flex">
      <a href={baseUrl} class="text-[#1A1A1A] transition-colors hover:text-[#1F7A63]">Home</a>
      <a href={`${baseUrl}services`} class="text-[#1A1A1A] transition-colors hover:text-[#1F7A63]">Services</a>
      <a
        href="https://erp.brighthorizon.co.za"
        target="_blank"
        rel="noreferrer"
        class="text-[#1A1A1A] transition-colors hover:text-[#1F7A63]"
      >
        Solutions
      </a>
      <a href={`${baseUrl}about`} class="text-[#1A1A1A] transition-colors hover:text-[#1F7A63]">About Us</a>
      <a
        href={`${baseUrl}contact`}
        class="btn-primary btn-shine rounded-full px-5 py-2 text-white shadow-md shadow-[#145A46]/30"
      >
        Get Started
      </a>
    </div>

    <details class="md:hidden">
      <summary class="cursor-pointer list-none rounded-lg border border-[#1F7A63]/25 px-3 py-2 text-sm font-semibold text-[#145A46]">
        Menu
      </summary>
      <div class="absolute right-6 mt-2 flex w-52 flex-col rounded-xl border border-[#1F7A63]/10 bg-[#FAF7F2] p-3 shadow-lg">
        <a href={baseUrl} class="rounded-lg px-3 py-2 text-sm font-semibold text-[#1A1A1A] hover:bg-[#1F7A63]/10">Home</a>
        <a href={`${baseUrl}services`} class="rounded-lg px-3 py-2 text-sm font-semibold text-[#1A1A1A] hover:bg-[#1F7A63]/10">Services</a>
        <a href="https://erp.brighthorizon.co.za" target="_blank" rel="noreferrer" class="rounded-lg px-3 py-2 text-sm font-semibold text-[#1A1A1A] hover:bg-[#1F7A63]/10">Solutions</a>
        <a href={`${baseUrl}about`} class="rounded-lg px-3 py-2 text-sm font-semibold text-[#1A1A1A] hover:bg-[#1F7A63]/10">About Us</a>
        <a href={`${baseUrl}contact`} class="rounded-lg px-3 py-2 text-sm font-semibold text-[#1A1A1A] hover:bg-[#1F7A63]/10">Contact</a>
      </div>
    </details>
  </div>
</nav>