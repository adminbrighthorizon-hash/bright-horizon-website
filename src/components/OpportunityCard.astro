---
interface Props {
  title: string;
  description: string;
  image: string;
}

const { title, description, image } = Astro.props;
---

<article class="section-shell group overflow-hidden">
  <img
    src={image}
    alt={title}
    loading="lazy"
    decoding="async"
    class="h-52 w-full object-cover transition duration-500 group-hover:scale-105"
  />
  <div class="p-6">
    <h3 class="mb-2 text-lg font-semibold text-[#145A46]">{title}</h3>
    <p class="text-sm leading-relaxed text-[#1A1A1A]/85">{description}</p>
  </div>
</article>
