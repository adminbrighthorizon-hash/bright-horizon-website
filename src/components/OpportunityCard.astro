---
interface Props {
  title: string;
  description: string;
  image: string;
}

const { title, description, image } = Astro.props;
---

<article class="section-shell group overflow-hidden">
  <img
    src={image}
    alt={title}
    loading="lazy"
    decoding="async"
    class="h-56 w-full object-cover transition duration-700 group-hover:scale-110"
  />
  <div class="p-6">
    <h3 class="mb-2 text-lg font-semibold text-[#103B34]">{title}</h3>
    <p class="text-sm leading-relaxed text-[#1A1A1A]/85">{description}</p>
    <div class="mt-5 h-1 w-16 rounded-full bg-[#B38A4A]/75"></div>
  </div>
</article>
