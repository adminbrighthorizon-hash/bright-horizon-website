---
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content="Bright Horizon - Professional web development, business systems, and cloud infrastructure solutions." />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg?v=4`} />
		<meta name="generator" content={Astro.generator} />
		<title>Bright Horizon - Digital Development Studio</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
