---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Bright Horizon | Technology Meets Opportunity",
  description = "Premium IT services, IAM, automation, cloud solutions, and business opportunity facilitation across Africa."
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1F7A63" />
    <link rel="icon" type="image/png" href={`${baseUrl}horizon1.png`} />
    <link rel="apple-touch-icon" href={`${baseUrl}horizon1.png`} />
    <title>{title}</title>
  </head>

  <body class="antialiased">

    <Navbar />

    <main>
      <slot />
    </main>

    <Footer />

  </body>
</html>