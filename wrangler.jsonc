{
	"compatibility_date": "2026-05-01",
	"name": "bright-horizon-website",
	"workers_dev": true,
	"main": "worker.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "www.brighthorizon.co.za",
			"custom_domain": true
		}
	]
}